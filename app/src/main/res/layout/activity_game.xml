<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/pink_primary"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Memory Flip"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/tvMoves"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moves: 0"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvPairs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pairs: 0/8"
            android:textSize="14sp"
            android:textColor="@color/white"/>

    </LinearLayout>

    <!-- Challenge moves-left warning bar (hidden in classic mode) -->
    <LinearLayout
        android:id="@+id/challengeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/pink_dark"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ Challenge Mode"
            android:textSize="13sp"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/tvMovesLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moves Left: 20"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

    </LinearLayout>

    <!-- Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- Restart button -->
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="180dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_restart"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/button_pink"
        android:elevation="4dp"/>

</LinearLayout>